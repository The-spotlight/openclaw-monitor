PORT=3000
NODE_ENV=production

# 采集配置
SAMPLE_INTERVAL=2000
HISTORY_SIZE=30
HEALTH_CHECK_INTERVAL=30000

# 阈值
CPU_WARN_THRESHOLD=80
MEM_WARN_THRESHOLD=90

# 会话
SESSION_IDLE_TIMEOUT=60000
SESSION_REMOVE_TIMEOUT=300000
SESSION_CLEANUP_INTERVAL=10000

# 日志
MAX_LOGS=200

# 安全
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# 持久化
DATA_DIR=./data
DATA_RETENTION_HOURS=24
